{
    "name": "multiplayer-api/web-constructor",
    "description": "Multiplayer API Web Constructor with PayPal/Paynet payments and MAIB Moldova support",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Multiplayer API Team",
            "email": "support@yourdomain.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "vlucas/phpdotenv": "^5.6",
        "paypal/rest-api-sdk-php": "^1.14",
        "phpmailer/phpmailer": "^6.8",
        "ramsey/uuid": "^4.7",
        "monolog/monolog": "^3.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "MultiplayerAPI\\": "classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MultiplayerAPI\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyze": "phpstan analyse",
        "style-check": "phpcs",
        "style-fix": "phpcbf",
        "setup": [
            "@composer install",
            "cp .env.example .env",
            "echo 'Please update .env file with your configuration'"
        ],
        "deploy": [
            "@composer install --no-dev --optimize-autoloader",
            "@style-check",
            "@analyze"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
