# Multiplayer API Environment Configuration
# Copy this file to .env and update with your actual database credentials

# Database Configuration (MySQL on Hostinger)
DB_HOST=localhost
DB_NAME=u833544264_multiplayer_api
DB_USERNAME=u833544264_api_user
DB_PASSWORD=your_secure_mysql_password
DB_CHARSET=utf8mb4

# API Configuration
API_SECRET_KEY=your_secret_api_key_here
API_TOKEN_EXPIRY=3600
DEBUG_MODE=false

# Email Configuration (SMTP) - Hostinger Settings
# Use port 465 for SSL or port 587 for TLS/STARTTLS
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=support@michitai.com
SMTP_PASSWORD=your_email_password
SMTP_FROM_EMAIL=support@michitai.com
SMTP_FROM_NAME="Multiplayer API Support"

# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENVIRONMENT=sandbox

# System Configuration
SITE_URL=https://api.michitai.com
API_BASE_URL=https://api.michitai.com/api

# File Paths (Hostinger structure)
LOGS_PATH=logs/
UPLOADS_PATH=uploads/_key_here
JWT_SECRET=your_jwt_secret_here
