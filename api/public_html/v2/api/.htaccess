# Security configuration for API directory
# Protect sensitive files and directories

# Block access to sensitive files
<FilesMatch "\.(env|log|sql|md|json|lock|bak|backup|old|tmp|sh|db)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Block access to configuration files
<FilesMatch "(config|classes)">
</DirectoryMatch>

# Block sensitive file extensions
<FilesMatch "\.(env|log|db|json|sql|ini|conf|bak|backup|old|tmp)$">
    Require all denied
</FilesMatch>

# Block direct access to all PHP files except allowed ones
<FilesMatch "\.php$">
    Require all denied
</FilesMatch>

# Allow specific PHP files for API and testing
<Files "index.php">
    Require all granted
</Files>

<Files "test.php">
    Require all granted
</Files>

<Files "minimal.php">
    Require all granted
</Files>

<Files "mysql_test.php">
    Require all granted
</Files>

<Files "structure_test.php">
    Require all granted
</Files>

<Files "registration_test.php">
    Require all granted
</Files>

# Block access to version control and system files
<FilesMatch "^\.(git|svn|htaccess|htpasswd)">
    Require all denied
</FilesMatch>

# Block access to composer files
<FilesMatch "^(composer\.(json|lock)|package\.(json|lock))$">
    Require all denied
</FilesMatch>

# Security headers
Header always set X-Content-Type-Options nosniff
Header always set X-Frame-Options DENY
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:;"

# Prevent information disclosure
ServerTokens Prod
Header unset Server
Header unset X-Powered-By

# Enable CORS for API endpoints (adjust origins as needed)
Header always set Access-Control-Allow-Origin "https://api.michitai.com"
Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
Header always set Access-Control-Max-Age "3600"

# Handle preflight requests
RewriteEngine On
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]
