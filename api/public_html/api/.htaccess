# Security configuration for API directory
# Protect sensitive files and directories

# Block access to sensitive files
<FilesMatch "\.(env|log|sql|md|json|lock|bak|backup|old|tmp|sh|db)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Block access to configuration files
<FilesMatch "(config|classes)">
    <Files "*.php">
        # Allow PHP execution but prevent direct access to config/class files
        # Only allow access through index.php
        RewriteEngine On
        RewriteCond %{THE_REQUEST} \s/+api/(config|classes)/
        RewriteRule ^ - [F,L]
    </Files>
</FilesMatch>

# Block access to data directory (contains database)
<DirectoryMatch "data">
    Order deny,allow
    Deny from all
</DirectoryMatch>

# Block access to logs directory
<DirectoryMatch "logs">
    Order deny,allow
    Deny from all
</DirectoryMatch>

# Block access to hidden files and directories
<FilesMatch "^\.">
    Order deny,allow
    Deny from all
</FilesMatch>

# Only allow access to index.php, test.php, and minimal.php
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !^.*(index|test|minimal)\.php$
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_FILENAME} \.php$
RewriteRule ^(.*)$ - [F,L]

# Security headers for API responses
Header always set X-Content-Type-Options nosniff
Header always set X-Frame-Options DENY
Header always set X-XSS-Protection "1; mode=block"
