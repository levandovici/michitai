# Multiplayer API Environment Configuration
# Copy this file to .env and update with your actual database credentials

# Database Configuration (Hostinger MySQL)
DB_HOST=localhost
DB_DATABASE=u833544264_multiplayer_api
DB_USERNAME=u833544264_api_user
DB_PASSWORD=your_database_password_here

# API Configuration
API_DEBUG=true
API_ENVIRONMENT=development

# Email Configuration (for production)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USERNAME=your_email@michitai.com
SMTP_PASSWORD=your_email_password
SMTP_FROM_EMAIL=noreply@michitai.com
SMTP_FROM_NAME=Multiplayer API

# PayPal Configuration (for production)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENVIRONMENT=sandbox

# Security
API_SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here
