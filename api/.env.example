# Multiplayer API Web Constructor - Environment Configuration
# Copy this file to .env and update with your actual values

# Database Configuration (Hostinger MySQL)
DB_HOST=localhost
DB_NAME=multiplayer_api
DB_USERNAME=your_mysql_username
DB_PASSWORD=your_mysql_password

# PayPal Configuration
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_RETURN_URL=https://yourdomain.com/payment/success
PAYPAL_CANCEL_URL=https://yourdomain.com/payment/cancel

# Paynet Configuration (Moldova)
PAYNET_RETURN_URL=https://yourdomain.com/payment/success
PAYNET_CANCEL_URL=https://yourdomain.com/payment/cancel

# SMTP Configuration for Email Notifications
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USERNAME=your_email@yourdomain.com
SMTP_PASSWORD=your_email_password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Multiplayer API Constructor

# Slack Configuration for Pro Users
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Security
JWT_SECRET=your_jwt_secret_key_here
API_RATE_LIMIT_WINDOW=3600

# Application URLs
APP_URL=https://yourdomain.com
API_URL=https://yourdomain.com/api

# File Upload Limits
MAX_UPLOAD_SIZE=10485760
MAX_FILES_PER_USER=100

# Cache Configuration
CACHE_DRIVER=file
CACHE_TTL=3600

# Debug Mode (set to false in production)
DEBUG_MODE=false
LOG_LEVEL=error

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30
