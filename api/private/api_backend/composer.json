{
    "name": "michitai/api-constructor",
    "description": "Professional Multiplayer API Constructor Backend",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.0",
        "vlucas/phpdotenv": "^5.5",
        "paypal/paypal-server-sdk": "^0.4",
        "phpmailer/phpmailer": "^6.8",
        "ramsey/uuid": "^4.7",
        "monolog/monolog": "^2.9",
        "guzzlehttp/guzzle": "^7.8",
        "psr/log": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.3",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "Michitai\\API\\": "classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Michitai\\API\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
