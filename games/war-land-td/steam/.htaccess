###############################################
# ENABLE URL REWRITING
###############################################
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect index.html to /
  RewriteCond %{THE_REQUEST} /index\.html [NC]
  RewriteRule ^index\.html$ / [R=301,L]
</IfModule>


###############################################
# SECURITY: PREVENT DIRECTORY BROWSING
###############################################
Options -Indexes


###############################################
# DEFAULT DOCUMENT
###############################################
DirectoryIndex index.html


###############################################
# MIME TYPES
###############################################
AddType application/json .json


###############################################
# CACHING HEADERS
###############################################
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 1 day"
</IfModule>


###############################################
# SECURITY: BLOCK ACCESS TO HIDDEN FILES
###############################################
<FilesMatch "^\.">
  Order Allow,Deny
  Deny from all
</FilesMatch>


###############################################
# PROTECT app-ads.txt FROM FLOODING / DDoS
###############################################
<Files "app-ads.txt">
   <IfModule mod_rewrite.c>
      RewriteEngine On

      # Soft rate-limit: track hits and block if too many
      RewriteCond %{REQUEST_URI} ^/app-ads\.txt$ [NC]
      RewriteCond %{ENV:APPADS_LIMIT} >10
      RewriteRule .* - [F,L]

      # Counting hits per process
      RewriteCond %{REQUEST_URI} ^/app-ads\.txt$ [NC]
      RewriteRule .* - [E=APPADS_LIMIT:+1]
   </IfModule>

   # Block known bad bots hitting app-ads.txt
   BrowserMatchNoCase "curl|wget|python|bot|crawler|spider" bad_bot
   Order Allow,Deny
   Allow from all
   Deny from env=bad_bot
</Files>


###############################################
# GENERAL ANTI-DDoS RATE LIMITING (LIGHTWEIGHT)
###############################################
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block extremely fast repeated requests from same IP
  RewriteCond %{REQUEST_URI} !/robots\.txt$ [NC]
  RewriteCond %{ENV:LIMIT_EXCEEDED} =1
  RewriteRule .* - [F]

  # Limit request count (simple in-memory system)
  RewriteCond %{ENV:REQ_LIMIT} >120
  RewriteRule .* - [E=LIMIT_EXCEEDED:1]

  RewriteRule .* - [E=REQ_LIMIT:+1]
</IfModule>


###############################################
# ADDITIONAL BOT PROTECTION
###############################################
<IfModule mod_setenvif.c>
  SetEnvIfNoCase User-Agent "curl" bad_bot
  SetEnvIfNoCase User-Agent "wget" bad_bot
  SetEnvIfNoCase User-Agent "python" bad_bot
  SetEnvIfNoCase User-Agent "scraper" bad_bot
  SetEnvIfNoCase User-Agent "crawler" bad_bot
  SetEnvIfNoCase User-Agent "spider" bad_bot
</IfModule>

<Limit GET POST>
  Order Allow,Deny
  Allow from all
  Deny from env=bad_bot
</Limit>

